# MODO Application — environment variables
# Copy to .env and fill in secrets:  cp .env.example .env

# --- PostgreSQL (docker compose) ---
POSTGRES_USER=modo
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_DB=modo
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Backend (Express, port 4000) ---
DATABASE_URL=postgresql://modo:replace-with-a-strong-password@localhost:5432/modo
JWT_SECRET=replace-with-a-random-jwt-secret
PORT=4000
FRONTEND_ORIGIN=http://localhost:5173
NODE_ENV=development

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
PINECONE_API_KEY=

IBGE_API_URL=https://servicodados.ibge.gov.br/api/v1
BCB_API_URL=https://api.bcb.gov.br
